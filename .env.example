# AI Search OS — copy to .env

# Active site (see config/sites_registry.json)
ASOS_SITE_ID=demo
ASOS_DB_PATH=D:\AISearchOS\data\demo_site.db

# API keys (optional for rules-only mode)
OPENAI_API_KEY=
SERPAPI_KEY=

# DataForSEO
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en

# Trends MCP
TRENDS_MCP_API_KEY=
TRENDS_MCP_API_URL=https://api.trendsmcp.ai/api

# Multi-engine AI intent (Google + Bing + DuckDuckGo via SerpAPI)
AI_INTENT_ENGINES=google,bing,duckduckgo
AI_INTENT_BING_COPILOT=0
AI_INTENT_FORUMS=1

# Agent worker
AGENT_WORKER_POLL_SECONDS=30
AGENT_NOTIFY_DESKTOP=0

# Agent API (ai-search-os — port 8787)
AGENT_API_URL=http://localhost:8787
AGENT_API_KEY=your-key-here

# Citation Engine REST API (my-ai-seo citation_api — port 8510; Streamlit UI is 8501)
CITATION_ENGINE_URL=http://localhost:8510
