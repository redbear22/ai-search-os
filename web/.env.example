# OpenAI API Key (Clarity — ChatGPT tab)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-key-here

# Perplexity API (Clarity — Perplexity tab)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
PERPLEXITY_API_URL=https://api.perplexity.ai

# Anthropic Claude API (Clarity — Claude tab)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_API_URL=https://api.anthropic.com/v1

# Google Gemini API (Clarity — Google AI tab)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=
GOOGLE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# DataForSEO (discoverability / SERP data)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
DATAFORSEO_LOCATION_CODE=2840
DATAFORSEO_LANGUAGE_CODE=en

# Trends MCP (free tier: 100 requests/mo)
TRENDS_MCP_API_KEY=
TRENDS_MCP_API_URL=https://api.trendsmcp.ai/api
# TRENDS_MCP_URL=https://api.trendsmcp.ai  # alias; /api appended if missing

# Keywords Everywhere (Discoverability)
KEYWORDS_EVERYWHERE_API_KEY=
KEYWORDS_EVERYWHERE_API_URL=https://api.keywordseverywhere.com/v1
KE_DEFAULT_COUNTRY=us
KE_DEFAULT_CURRENCY=USD

# Keepa (Amazon product/pricing — optional)
KEEPA_API_KEY=

# Google Search Console (OAuth — optional)
GSC_ENABLED=false
GOOGLE_GSC_CLIENT_ID=
GOOGLE_GSC_CLIENT_SECRET=
GOOGLE_GSC_REFRESH_TOKEN=

# Turn on the integration (Citation Engine REST API — port 8510; Streamlit UI is 8501)
CITATION_ENGINE_ENABLED=true
CITATION_ENGINE_URL=http://localhost:8510

# Agent API (if running — port 8787)
AGENT_API_ENABLED=true
AGENT_API_URL=http://localhost:8787
AGENT_API_KEY=your-key-here

# Anonymous analytics — opt-in data moat (no PII, aggregated patterns only)
# Next.js only reads web/.env.local (repo-root .env.local is for Python/Streamlit)
# Enable analytics (set to true after consent is implemented)
# Google Analytics 4 (page views via @next/third-parties)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FQF0KK04JJ

NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_ENDPOINT=/api/analytics/track
# Secret for viewing analytics data (/admin/analytics)
ANALYTICS_SECRET=your-secret-key-here
# ANALYTICS_FILE=analytics-data.json

# Auth database (Prisma + NextAuth)
# Local dev: SQLite file (zero setup; created on first migrate)
DATABASE_URL=file:./prisma/dev.db
# Vercel/serverless: SQLite file URLs do NOT work (ephemeral filesystem).
# Use a hosted DB instead, e.g. Vercel Postgres, Neon, or Turso, and switch
# prisma/schema.prisma provider to "postgresql" (or sqlite+libsql for Turso).
# Example: DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Google Knowledge Graph (optional — Entity Trust pillar)
GOOGLE_KNOWLEDGE_API_KEY=

# NextAuth — must match the URL you use in the browser AND Google redirect URI host
NEXTAUTH_URL=http://localhost:3000
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth (sign-in — separate from Gemini / GSC keys above)
# Redirect URI: http://localhost:3000/api/auth/callback/google
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LAN / Chrome localhost workaround (development only)
# Google OAuth cannot use 192.168.x.x redirect URIs. If you only reach the app via LAN IP,
# set DEV_AUTH_BYPASS=true and DEV_AUTH_EMAIL to an APPROVED/ADMIN user in the SQLite DB.
DEV_AUTH_BYPASS=false
DEV_AUTH_EMAIL=

# Citation Monitor — weekly Vercel Cron (Mondays 9:00 UTC)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-cron-secret-here

# API protection — internal scripts + enterprise request signing
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=
API_SIGNING_SECRET=

# Optional Upstash Redis for distributed IP rate limiting (100 req/hour/IP)
# Falls back to in-memory when unset. https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional email report (Resend — https://resend.com)
# RESEND_API_KEY=
# RESEND_FROM=AI Search OS <reports@yourdomain.com>
# CITATION_MONITOR_NOTIFY_EMAIL=you@company.com
# Vercel/serverless fallback when file storage is unavailable:
# CITATION_MONITOR_CRON_CONFIG={"brandName":"Acme","queries":["best widget"],"competitors":["Rival"],"enabled":true}

# Bootstrap first admin:
# 1) Sign in with Google (creates PENDING) → npm run db:studio -w web → role ADMIN
# 2) Before sign-in: npx tsx web/scripts/seed-approved-user.ts you@company.com ADMIN
