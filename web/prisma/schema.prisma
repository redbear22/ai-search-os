generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole         @default(PENDING)
  agencyId      String?
  agency        Agency?          @relation("AgencyMembers", fields: [agencyId], references: [id])
  clientId      String?
  client        Client?          @relation("ClientViewers", fields: [clientId], references: [id])
  agencyRole    AgencyRole       @default(AGENCY_TEAM)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  sessions      Session[]
  ownedAgencies Agency[]         @relation("AgencyOwner")
  assignments   AgencyMemberAssignment[]
  invitesSent   AgencyInvite[]   @relation("InviteSender")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agency {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  logo           String?
  primaryColor   String          @default("#3b82f6")
  ownerId        String
  owner          User            @relation("AgencyOwner", fields: [ownerId], references: [id])
  users          User[]          @relation("AgencyMembers")
  clients        Client[]
  subscription   Subscription?
  invites        AgencyInvite[]
  branding       AgencyBranding?
  apiKeys        ApiKey[]
  oauthClients   OAuthClient[]
  apiWebhooks    ApiWebhook[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  agencyId   String
  agency     Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String    @default("[]")
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model OAuthClient {
  id               String   @id @default(uuid())
  clientId         String   @unique
  clientSecretHash String
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name             String   @default("OAuth Client")
  redirectUris     String   @default("[]")
  scopes           String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApiWebhook {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  events    String   @default("[]")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HoneypotEvent {
  id        String   @id @default(uuid())
  ip        String
  path      String
  userAgent String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([createdAt])
}

model BlockedIp {
  id        String   @id @default(uuid())
  ip        String   @unique
  reason    String
  hitCount  Int      @default(1)
  blockedAt DateTime @default(now())
}

model CanaryLeak {
  id        String   @id @default(uuid())
  token     String
  ip        String
  source    String
  path      String
  createdAt DateTime @default(now())

  @@index([token])
  @@index([createdAt])
}

model ApiAccessLog {
  id         String   @id @default(uuid())
  ip         String
  path       String
  method     String
  status     Int
  authType   String
  userId     String?
  agencyId   String?
  apiKeyId   String?
  userAgent  String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([ip, createdAt])
  @@index([path, createdAt])
}

model AgencyBranding {
  id             String   @id @default(uuid())
  agencyId       String   @unique
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  secondaryColor String   @default("#64748b")
  fontFamily     String   @default("Inter")
  customDomain   String?
  favicon        String?
  portalName     String?
  reportHeader   String?
  reportFooter   String?
  features       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Client {
  id          String          @id @default(uuid())
  name        String
  domain      String?
  agencyId    String
  agency      Agency          @relation(fields: [agencyId], references: [id])
  audits      Audit[]
  actionPlans ActionPlan[]
  gaps        Gap[]
  settings    ClientSettings?
  viewers     User[]          @relation("ClientViewers")
  assignments            AgencyMemberAssignment[]
  autonomousAuditConfig  AutonomousAuditConfig?
  autonomousAuditRuns    AutonomousAuditRun[]
  fixPipelineRuns        FixPipelineRun[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model FixPipelineRun {
  id               String    @id @default(uuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  gapId            String?
  pipelineType     String
  status           String    @default("running")
  currentStep      String
  steps            Json
  gapSnapshot      Json
  requiresApproval Boolean   @default(false)
  approvedAt       DateTime?
  approvedBy       String?
  sentAt           DateTime?
  followupAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
}

model AutonomousAuditConfig {
  id                     String    @id @default(uuid())
  clientId               String    @unique
  client                 Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enabled                Boolean   @default(false)
  auditFrequency         String    @default("weekly")
  optimizedFrequency     String?
  nextAuditAt            DateTime?
  lastAuditAt            DateTime?
  triggerCitationSpike   Boolean   @default(true)
  triggerPlatformRelease Boolean   @default(true)
  triggerDomainChange    Boolean   @default(true)
  triggerWebhook         Boolean   @default(true)
  webhookSecret          String?   @unique
  autoAssign             Boolean   @default(true)
  notifyClient           Boolean   @default(false)
  lastKnownDomain        String?
  citationBaseline       Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model AutonomousAuditRun {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggerType     String
  status          String    @default("pending")
  gapsDetected    Int       @default(0)
  gapsAssigned    Int       @default(0)
  gapsPrioritized Json?
  notifiedClient  Boolean   @default(false)
  assigneeId      String?
  auditId         String?
  intelligence    Json?
  errorMessage    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
}

model GapFixLearning {
  id           String   @id @default(uuid())
  agencyId     String
  layer        String
  severity     String
  patternKey   String
  successCount Int      @default(0)
  attemptCount Int      @default(0)
  successRate  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([agencyId, patternKey])
}

model PlatformReleaseEvent {
  id         String   @id @default(uuid())
  platform   String
  version    String
  releasedAt DateTime @default(now())
  processed  Boolean  @default(false)
}

model AgencyMemberAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, clientId])
}

model AgencyInvite {
  id         String     @id @default(uuid())
  email      String
  agencyId   String
  agency     Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyRole AgencyRole @default(AGENCY_TEAM)
  clientId   String?
  clientIds  String?
  invitedBy  String
  inviter    User       @relation("InviteSender", fields: [invitedBy], references: [id])
  token      String     @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([agencyId, email])
}

model ClientSettings {
  id               String    @id @default(uuid())
  clientId         String    @unique
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reportFrequency  String    @default("monthly")
  shareWithClient  Boolean   @default(false)
  clientAccessKey  String?   @unique
  agencyLogo       String?
  brandColor       String?
  reportFooterText String?
  emailReports     Boolean   @default(false)
  nextReportAt     DateTime?
  lastReportAt     DateTime?
}

model Subscription {
  id                   String    @id @default(uuid())
  agencyId             String    @unique
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  plan                 PlanType  @default(FREE)
  status               String    @default("active")
  clientLimit          Int       @default(1)
  teamMemberLimit      Int       @default(1)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Audit {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  brandName String
  domain    String
  auditData Json
  gapCount  Int
  createdAt DateTime @default(now())
}

model ActionPlan {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description  String
  ownerTeam    String
  ownerPerson  String?
  dueWeek      Int?
  status       String   @default("pending")
  layerId      String?
  resourceAsks Json?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Gap {
  id                String   @id @default(uuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  layer             String
  severity          String
  title             String
  description       String
  suggestedOwner    String?
  suggestedTimeline String?
  status            String   @default("open")
  sourceData        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum UserRole {
  PENDING
  APPROVED
  ADMIN
}

enum AgencyRole {
  AGENCY_OWNER
  AGENCY_ADMIN
  AGENCY_TEAM
  CLIENT_VIEWER
}

enum PlanType {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}
