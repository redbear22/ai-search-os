generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole         @default(PENDING)
  agencyId      String?
  agency        Agency?          @relation("AgencyMembers", fields: [agencyId], references: [id])
  clientId      String?
  client        Client?          @relation("ClientViewers", fields: [clientId], references: [id])
  agencyRole    AgencyRole       @default(AGENCY_TEAM)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  accounts      Account[]
  sessions      Session[]
  ownedAgencies Agency[]         @relation("AgencyOwner")
  assignments   AgencyMemberAssignment[]
  invitesSent   AgencyInvite[]   @relation("InviteSender")
  audits        Audit[]
  auditJobs     AuditJob[]
  fixJobs       FixJob[]
  taskProjects  TaskProject[]
  domains       Domain[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agency {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  logo           String?
  primaryColor   String          @default("#3b82f6")
  ownerId        String
  owner          User            @relation("AgencyOwner", fields: [ownerId], references: [id])
  users          User[]          @relation("AgencyMembers")
  clients        Client[]
  subscription   Subscription?
  invites        AgencyInvite[]
  branding       AgencyBranding?
  apiKeys        ApiKey[]
  oauthClients   OAuthClient[]
  apiWebhooks    ApiWebhook[]
  domains        Domain[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model ApiKey {
  id         String    @id @default(uuid())
  agencyId   String
  agency     Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  scopes     String    @default("[]")
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model OAuthClient {
  id               String   @id @default(uuid())
  clientId         String   @unique
  clientSecretHash String
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  name             String   @default("OAuth Client")
  redirectUris     String   @default("[]")
  scopes           String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ApiWebhook {
  id        String   @id @default(uuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  url       String
  secret    String
  events    String   @default("[]")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model HoneypotEvent {
  id        String   @id @default(uuid())
  ip        String
  path      String
  userAgent String?
  blocked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([createdAt])
}

model BlockedIp {
  id        String   @id @default(uuid())
  ip        String   @unique
  reason    String
  hitCount  Int      @default(1)
  blockedAt DateTime @default(now())
}

model CanaryLeak {
  id        String   @id @default(uuid())
  token     String
  ip        String
  source    String
  path      String
  createdAt DateTime @default(now())

  @@index([token])
  @@index([createdAt])
}

model ApiAccessLog {
  id         String   @id @default(uuid())
  ip         String
  path       String
  method     String
  status     Int
  authType   String
  userId     String?
  agencyId   String?
  apiKeyId   String?
  userAgent  String?
  durationMs Int?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([ip, createdAt])
  @@index([path, createdAt])
}

model AgencyBranding {
  id             String   @id @default(uuid())
  agencyId       String   @unique
  agency         Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  secondaryColor String   @default("#64748b")
  fontFamily     String   @default("Inter")
  customDomain   String?
  favicon        String?
  portalName     String?
  reportHeader   String?
  reportFooter   String?
  features       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Client {
  id          String          @id @default(uuid())
  name        String
  domain      String?
  agencyId    String
  agency      Agency          @relation(fields: [agencyId], references: [id])
  audits      Audit[]
  actionPlans ActionPlan[]
  gaps        Gap[]
  settings    ClientSettings?
  viewers     User[]          @relation("ClientViewers")
  assignments            AgencyMemberAssignment[]
  autonomousAuditConfig  AutonomousAuditConfig?
  autonomousAuditRuns    AutonomousAuditRun[]
  fixPipelineRuns        FixPipelineRun[]
  taskProjects           TaskProject[]
  auditJobs              AuditJob[]
  fixJobs                FixJob[]
  domains                Domain[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model FixPipelineRun {
  id               String    @id @default(uuid())
  clientId         String
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  gapId            String?
  pipelineType     String
  status           String    @default("running")
  currentStep      String
  steps            Json
  gapSnapshot      Json
  requiresApproval Boolean   @default(false)
  approvedAt       DateTime?
  approvedBy       String?
  sentAt           DateTime?
  followupAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?
}

model AutonomousAuditConfig {
  id                     String    @id @default(uuid())
  clientId               String    @unique
  client                 Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enabled                Boolean   @default(false)
  auditFrequency         String    @default("weekly")
  optimizedFrequency     String?
  nextAuditAt            DateTime?
  lastAuditAt            DateTime?
  triggerCitationSpike   Boolean   @default(true)
  triggerPlatformRelease Boolean   @default(true)
  triggerDomainChange    Boolean   @default(true)
  triggerWebhook         Boolean   @default(true)
  webhookSecret          String?   @unique
  autoAssign             Boolean   @default(true)
  notifyClient           Boolean   @default(false)
  lastKnownDomain        String?
  citationBaseline       Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model AutonomousAuditRun {
  id              String    @id @default(uuid())
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  triggerType     String
  status          String    @default("pending")
  gapsDetected    Int       @default(0)
  gapsAssigned    Int       @default(0)
  gapsPrioritized Json?
  notifiedClient  Boolean   @default(false)
  assigneeId      String?
  auditId         String?
  intelligence    Json?
  errorMessage    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
}

model GapFixLearning {
  id           String   @id @default(uuid())
  agencyId     String
  layer        String
  severity     String
  patternKey   String
  successCount Int      @default(0)
  attemptCount Int      @default(0)
  successRate  Float    @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([agencyId, patternKey])
}

model PlatformReleaseEvent {
  id         String   @id @default(uuid())
  platform   String
  version    String
  releasedAt DateTime @default(now())
  processed  Boolean  @default(false)
}

model AgencyMemberAssignment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, clientId])
}

model AgencyInvite {
  id         String     @id @default(uuid())
  email      String
  agencyId   String
  agency     Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  agencyRole AgencyRole @default(AGENCY_TEAM)
  clientId   String?
  clientIds  String?
  invitedBy  String
  inviter    User       @relation("InviteSender", fields: [invitedBy], references: [id])
  token      String     @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime   @default(now())

  @@unique([agencyId, email])
}

model ClientSettings {
  id               String    @id @default(uuid())
  clientId         String    @unique
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  reportFrequency  String    @default("monthly")
  shareWithClient  Boolean   @default(false)
  clientAccessKey  String?   @unique
  agencyLogo       String?
  brandColor       String?
  reportFooterText String?
  emailReports     Boolean   @default(false)
  nextReportAt     DateTime?
  lastReportAt     DateTime?
}

model Subscription {
  id                   String    @id @default(uuid())
  agencyId             String    @unique
  agency               Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  plan                 PlanType  @default(FREE)
  status               String    @default("active")
  clientLimit          Int       @default(1)
  teamMemberLimit      Int       @default(1)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Audit {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  brandName   String
  domain      String
  auditData   Json
  gapCount    Int      @default(0)
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  gaps        Gap[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId, updatedAt])
  @@index([userId])
}

model ActionPlan {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  description  String
  ownerTeam    String
  ownerPerson  String?
  dueWeek      Int?
  status       String   @default("pending")
  layerId      String?
  resourceAsks Json?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Gap {
  id                String   @id @default(uuid())
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  auditId           String?
  audit             Audit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)
  layer             String
  severity          String
  title             String
  description       String
  suggestedOwner    String?
  suggestedTimeline String?
  status            String   @default("open")
  fixGenerated      Json?
  sourceData        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientId, status])
  @@index([auditId])
}

model TaskProject {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  sortOrder   Int      @default(0)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId, sortOrder])
}

model Task {
  id                    String      @id @default(uuid())
  projectId             String
  project               TaskProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title                 String
  description           String      @default("")
  status                String      @default("not_started")
  priority              String      @default("medium")
  gapId                 String?
  checklist             Json        @default("[]")
  dueDate               DateTime?
  estimatedTime         String      @default("")
  assignedTo            String?
  suggestedActionPlan   String      @default("")
  resourcesNeeded       Json        @default("[]")
  sortOrder             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  completedAt           DateTime?

  @@index([projectId, sortOrder])
}

enum UserRole {
  PENDING
  APPROVED
  ADMIN
}

enum AgencyRole {
  AGENCY_OWNER
  AGENCY_ADMIN
  AGENCY_TEAM
  CLIENT_VIEWER
}

enum PlanType {
  FREE
  PRO
  AGENCY
  ENTERPRISE
}

/// Agency-scoped domain registry for plan limits (who added it: userId).
model Domain {
  id               String   @id @default(cuid())
  agencyId         String
  agency           Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId           String
  clientId         String?
  client           Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  url              String
  isActive         Boolean  @default(true)
  treatAsSeparate  Boolean  @default(false)
  separationReason String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])

  @@unique([agencyId, url])
  @@index([agencyId, isActive])
  @@index([clientId])
}

/// Agent API — async audit jobs (arq worker + Postgres state of record)
model AuditJob {
  id        String         @id @default(uuid())
  siteUrl   String         @map("site_url")
  clientId  String?        @map("client_id")
  client    Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status    AuditJobStatus @default(QUEUED)
  progress  Int            @default(0)
  stage     String?
  error     String?
  result    Json?
  createdBy String         @map("created_by")
  user      User           @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@index([createdBy])
  @@index([clientId])
  @@index([status])
  @@map("audit_jobs")
}

enum AuditJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

/// Agent API — async fix jobs (arq worker + Postgres state of record; HITL gate)
model FixJob {
  id        String        @id @default(uuid())
  siteUrl   String        @map("site_url")
  clientId  String?       @map("client_id")
  client    Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  gapId     String?       @map("gap_id")
  status    FixJobStatus  @default(QUEUED)
  progress  Int           @default(0)
  stage     String?
  error     String?
  input     Json?
  result    Json?
  createdBy String        @map("created_by")
  user      User          @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([createdBy])
  @@index([clientId])
  @@index([status])
  @@map("fix_jobs")
}

enum FixJobStatus {
  QUEUED
  RUNNING
  NEEDS_APPROVAL
  DONE
  FAILED
}

/// Citation Engine — competitive audit reports (sources API)
model AbuseTracking {
  id        String   @id @default(uuid())
  ipAddress String   @map("ip_address")
  action    String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ipAddress, createdAt(sort: Desc)])
  @@index([action])
  @@map("abuse_tracking")
}

model CitationAuditRun {
  id               String   @id @default(uuid())
  siteId           String   @default("default") @map("site_id")
  projectProfileId Int      @default(1) @map("project_profile_id")
  keyword          String
  reportJson       Json     @map("report_json")
  winScore         Float    @default(0) @map("win_score")
  pagesAudited     Int      @default(0) @map("pages_audited")
  source           String   @default("")
  gapId            String?  @map("gap_id")
  rubricPct        Float    @default(0) @map("rubric_pct")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([siteId, keyword])
  @@index([siteId, projectProfileId, createdAt])
  @@map("citation_audit_runs")
}

/// Citation Engine — ingested content payloads (push from web / Agent API)
model CitationContentIngest {
  id        String   @id @default(uuid())
  siteId    String   @default("default") @map("site_id")
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([siteId, createdAt])
  @@map("citation_content_ingest")
}
